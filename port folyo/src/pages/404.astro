---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="404 — Sayfa Bulunamadı | Hanım ATAŞ" description="Aradığınız sayfa bulunamadı.">
  <Navbar />
  <main id="main-content" class="error-page">
    <div class="error-container">
      <div class="error-code">
        <span class="four">4</span>
        <span class="zero">
          <div class="gear">
            <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="3"/>
              <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/>
            </svg>
          </div>
        </span>
        <span class="four">4</span>
      </div>
      
      <h1 class="error-title">Sayfa Bulunamadı</h1>
      <p class="error-message">Aradığınız sayfa taşınmış, silinmiş veya hiç var olmamış olabilir.</p>
      
      <div class="error-actions">
        <a href="/" class="btn btn-primary" id="error-home">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          Ana Sayfaya Dön
        </a>
        <a href="#iletisim" class="btn btn-secondary" id="error-contact">
          İletişime Geç
        </a>
      </div>

      <div class="error-terminal">
        <code>
          <span class="term-prompt">$</span> curl -I /page-not-found<br/>
          <span class="term-red">HTTP/1.1 404 Not Found</span><br/>
          <span class="term-prompt">$</span> <span class="term-cursor">▊</span>
        </code>
      </div>
    </div>
  </main>
  <Footer />
</Layout>

<style>
  .error-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 6rem 1.5rem;
    text-align: center;
  }

  .error-container {
    max-width: 550px;
  }

  .error-code {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .four {
    font-size: 5rem;
    font-weight: 900;
    background: var(--accent-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1;
  }

  .gear {
    color: var(--accent-primary);
    animation: spin 4s linear infinite;
  }

  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  .error-title {
    font-size: 1.75rem;
    margin-bottom: 0.75rem;
  }

  .error-message {
    font-size: 1rem;
    color: var(--text-secondary);
    margin-bottom: 2rem;
    max-width: 100%;
  }

  .error-actions {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    margin-bottom: 2.5rem;
    flex-wrap: wrap;
  }

  .error-terminal {
    padding: 1.25rem;
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    font-family: var(--font-mono);
    font-size: 0.875rem;
    text-align: left;
    color: var(--text-secondary);
    line-height: 1.8;
  }

  .term-prompt {
    color: var(--success);
    font-weight: 600;
  }

  .term-red {
    color: var(--error);
  }

  .term-cursor {
    animation: blink 1s step-end infinite;
    color: var(--accent-primary);
  }

  @keyframes blink {
    0%, 50% { opacity: 1; }
    51%, 100% { opacity: 0; }
  }
</style>
