---
// Projects Section — 4 Real Projects
const projects = [
  {
    title: "SecScan",
    pitch: "Web uygulamalarının güvenlik açıklarını paralel olarak tarayan yüksek performanslı güvenlik platformu.",
    description: "7 farklı güvenlik modülünü Goroutine'ler ile eş zamanlı çalıştırarak XSS, SQL Injection, Header analizi gibi zaafiyetleri tespit eder. SSRF koruması için iki katmanlı validasyon mekanizması içerir.",
    tech: ["Go", "Gin", "Goroutines", "Docker", "React", "Next.js"],
    github: "https://github.com/HANIM23-ATAS/SecScan",
    contribution: "Tüm backend mimarisini, paralel tarama motorunu ve SSRF koruma katmanını sıfırdan geliştirdim.",
    icon: "shield",
    color: "#ef4444"
  },
  {
    title: "GoLearn",
    pitch: "Uzaktan eğitim platformu için kapsamlı REST API — kurslar, sınavlar ve gerçek zamanlı sınıflar.",
    description: "JWT kimlik doğrulama, rol tabanlı erişim kontrolü, kurs/ders yönetimi, quiz sistemi, ilerleme takibi ve WebSocket ile gerçek zamanlı sanal sınıf desteği sunar.",
    tech: ["Go", "Gin", "GORM", "SQLite", "WebSocket", "Swagger", "Docker"],
    github: "https://github.com/HANIM23-ATAS/golearn",
    contribution: "Backend API'nin tamamını, WebSocket sınıf sistemini ve Swagger dokümantasyonunu geliştirdim.",
    icon: "book",
    color: "#10b981"
  },
  {
    title: "CampusConnect",
    pitch: "Üniversite etkinliklerini birbirine bağlayan mikroservis mimarisiyle çalışan platform.",
    description: "NestJS ana API + Go analitik servisi + PostgreSQL. HMAC-SHA256 ile güvenli webhook iletişimi, GraphQL ile etkinlik katılımı, rate limiting ve Prisma ORM entegrasyonu.",
    tech: ["NestJS", "TypeScript", "Go", "PostgreSQL", "Prisma", "GraphQL", "Docker"],
    github: "https://github.com/HANIM23-ATAS/CampusConnect",
    contribution: "Mikroservis mimarisini tasarlayıp, servisler arası güvenli iletişim altyapısını kurdum.",
    icon: "users",
    color: "#3b82f6"
  },
  {
    title: "Task Manager",
    pitch: "Kanban tabanlı görev yönetim uygulaması — sürükle-bırak, önceliklendirme ve alt görev takibi.",
    description: "MERN stack ile geliştirilmiş full-stack uygulama. Drag & drop Kanban board, 4 seviye önceliklendirme, etiketleme, tarih bazlı uyarılar ve alt görev ilerleme takibi sunar.",
    tech: ["React", "Node.js", "Express", "MongoDB", "Tailwind CSS", "Vite"],
    github: "https://github.com/HANIM23-ATAS/task-manager",
    contribution: "Frontend Kanban board ve backend RESTful API'yi baştan sona geliştirdim.",
    icon: "kanban",
    color: "#8b5cf6"
  }
];

const iconPaths: Record<string, string> = {
  shield: "M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z",
  book: "M4 19.5A2.5 2.5 0 0 1 6.5 17H20M4 19.5A2.5 2.5 0 0 0 6.5 22H20V2H6.5A2.5 2.5 0 0 0 4 4.5v15z",
  users: "M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2M9 7a4 4 0 1 0 0-8 4 4 0 0 0 0 8zM23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75",
  kanban: "M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2V9M9 21H5a2 2 0 0 1-2-2V9m0 0h18"
};
---

<section id="projeler" class="projects" aria-label="Projeler">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-label">// Projeler</span>
      <h2 class="section-title">Üzerinde Çalıştığım <span class="gradient-text">Projeler</span></h2>
      <p class="section-subtitle">Tutorial kopyası değil — gerçek sorunları çözmek için geliştirdiğim projeler.</p>
    </div>

    <div class="projects-grid">
      {projects.map((project, i) => (
        <article class="project-card card reveal" style={`--project-color: ${project.color}; --delay: ${i * 0.1}s`}>
          <div class="project-header">
            <div class="project-icon" style={`background: ${project.color}15; border-color: ${project.color}25`}>
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke={project.color} stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d={iconPaths[project.icon]} />
              </svg>
            </div>
            <a href={project.github} target="_blank" rel="noopener noreferrer" class="project-github-link" aria-label={`${project.title} GitHub'da aç`}>
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77a5.07 5.07 0 0 0-.09-3.77S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
            </a>
          </div>

          <h3 class="project-title">{project.title}</h3>
          <p class="project-pitch">{project.pitch}</p>
          <p class="project-desc">{project.description}</p>

          <div class="project-tech">
            {project.tech.map((t) => (
              <span class="tag">{t}</span>
            ))}
          </div>

          <div class="project-contribution">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            <span>{project.contribution}</span>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .projects {
    background: var(--bg-secondary);
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .project-card {
    display: flex;
    flex-direction: column;
    transition-delay: var(--delay);
  }

  .project-card::before {
    background: linear-gradient(135deg, var(--project-color) 0%, transparent 100%);
  }

  .project-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
  }

  .project-icon {
    width: 44px;
    height: 44px;
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid;
  }

  .project-github-link {
    color: var(--text-tertiary);
    transition: all var(--transition-fast);
    padding: 0.375rem;
    border-radius: var(--radius-sm);
  }

  .project-github-link:hover {
    color: var(--accent-primary);
    background: rgba(102, 126, 234, 0.08);
  }

  .project-title {
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
    font-weight: 700;
  }

  .project-pitch {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
    line-height: 1.5;
  }

  .project-desc {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.65;
    margin-bottom: 1.25rem;
    flex-grow: 1;
  }

  .project-tech {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-bottom: 1.25rem;
  }

  .project-tech .tag {
    font-size: 0.75rem;
    padding: 0.2rem 0.6rem;
  }

  .project-contribution {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border-color);
    font-size: 0.8125rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  .project-contribution svg {
    color: var(--success);
    flex-shrink: 0;
    margin-top: 0.125rem;
  }

  @media (max-width: 768px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
