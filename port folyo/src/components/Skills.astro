---
// Skills Section — Kategorize + Dürüst
const skillCategories = [
  {
    title: "Programlama Dilleri",
    icon: "M16 18l6-6-6-6M8 6l-6 6 6 6",
    skills: [
      { name: "Go", level: 85, status: "İyi seviye" },
      { name: "TypeScript", level: 80, status: "İyi seviye" },
      { name: "JavaScript", level: 85, status: "İyi seviye" },
      { name: "Python", level: 60, status: "Temel seviye" },
      { name: "SQL", level: 75, status: "İyi seviye" }
    ]
  },
  {
    title: "Backend Frameworks",
    icon: "M22 12h-4l-3 9L9 3l-3 9H2",
    skills: [
      { name: "Gin (Go)", level: 85, status: "İyi seviye" },
      { name: "NestJS", level: 75, status: "İyi seviye" },
      { name: "Express.js", level: 80, status: "İyi seviye" },
      { name: "GORM", level: 75, status: "İyi seviye" },
      { name: "Prisma", level: 70, status: "Orta seviye" }
    ]
  },
  {
    title: "Frontend",
    icon: "M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5",
    skills: [
      { name: "React", level: 75, status: "İyi seviye" },
      { name: "Astro", level: 65, status: "Öğreniyorum" },
      { name: "HTML / CSS", level: 85, status: "İyi seviye" },
      { name: "Tailwind CSS", level: 70, status: "Orta seviye" },
      { name: "Next.js", level: 55, status: "Öğreniyorum" }
    ]
  },
  {
    title: "DevOps & Araçlar",
    icon: "M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09zM12 15l-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z",
    skills: [
      { name: "Docker", level: 80, status: "İyi seviye" },
      { name: "Docker Compose", level: 80, status: "İyi seviye" },
      { name: "GitHub Actions", level: 70, status: "Orta seviye" },
      { name: "nginx", level: 70, status: "Orta seviye" },
      { name: "Linux", level: 65, status: "Öğreniyorum" }
    ]
  },
  {
    title: "Veritabanı",
    icon: "M12 2C6.48 2 2 4.24 2 7v10c0 2.76 4.48 5 10 5s10-2.24 10-5V7c0-2.76-4.48-5-10-5z",
    skills: [
      { name: "PostgreSQL", level: 75, status: "İyi seviye" },
      { name: "MongoDB", level: 75, status: "İyi seviye" },
      { name: "SQLite", level: 70, status: "Orta seviye" },
      { name: "Redis", level: 45, status: "Başlangıç" }
    ]
  },
  {
    title: "Diğer",
    icon: "M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z",
    skills: [
      { name: "Git & GitHub", level: 85, status: "İyi seviye" },
      { name: "REST API", level: 90, status: "Güçlü" },
      { name: "GraphQL", level: 60, status: "Temel seviye" },
      { name: "WebSocket", level: 65, status: "Orta seviye" },
      { name: "Swagger/OpenAPI", level: 70, status: "Orta seviye" }
    ]
  }
];

function getLevelColor(level: number): string {
  if (level >= 80) return '#10b981';
  if (level >= 60) return '#667eea';
  if (level >= 40) return '#f59e0b';
  return '#94a3b8';
}
---

<section id="yetenekler" class="skills" aria-label="Yetenekler">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-label">// Yetenekler</span>
      <h2 class="section-title">Teknik <span class="gradient-text">Yeteneklerim</span></h2>
      <p class="section-subtitle">Dürüst bir değerlendirme — "uzmanım" demek yerine gerçek seviyemi gösteriyorum.</p>
    </div>

    <div class="skills-grid">
      {skillCategories.map((category, i) => (
        <div class="skill-category card reveal" style={`--delay: ${i * 0.08}s`}>
          <div class="skill-category-header">
            <div class="skill-category-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d={category.icon} />
              </svg>
            </div>
            <h3 class="skill-category-title">{category.title}</h3>
          </div>
          
          <div class="skill-list">
            {category.skills.map((skill) => (
              <div class="skill-item">
                <div class="skill-info">
                  <span class="skill-name">{skill.name}</span>
                  <span class="skill-status" style={`color: ${getLevelColor(skill.level)}`}>{skill.status}</span>
                </div>
                <div class="skill-bar">
                  <div class="skill-progress" style={`width: ${skill.level}%; background: ${getLevelColor(skill.level)}`}></div>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .skill-category {
    transition-delay: var(--delay);
  }

  .skill-category-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
  }

  .skill-category-icon {
    width: 38px;
    height: 38px;
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%);
    color: var(--accent-primary);
  }

  .skill-category-title {
    font-size: 1rem;
    font-weight: 700;
  }

  .skill-list {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  .skill-item {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .skill-info {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .skill-name {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-primary);
  }

  .skill-status {
    font-size: 0.75rem;
    font-weight: 500;
    font-family: var(--font-mono);
  }

  .skill-bar {
    width: 100%;
    height: 6px;
    background: var(--bg-tertiary);
    border-radius: var(--radius-full);
    overflow: hidden;
  }

  .skill-progress {
    height: 100%;
    border-radius: var(--radius-full);
    transition: width 1s ease-out;
  }

  @media (max-width: 1024px) {
    .skills-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .skills-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
