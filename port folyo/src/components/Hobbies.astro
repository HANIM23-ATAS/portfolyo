---
// Hobbies Section
const hobbies = [
  {
    emoji: "🎮",
    title: "Oyun Geliştirme",
    description: "Boş zamanlarımda oyun mekanikleri üzerine deneysel projeler geliştirmeyi seviyorum."
  },
  {
    emoji: "📚",
    title: "Teknik Kitaplar",
    description: "Sistem tasarımı ve yazılım mimarisi üzerine kitaplar okumayı tercih ediyorum."
  },
  {
    emoji: "🏃",
    title: "Doğa Yürüyüşü",
    description: "Hafta sonları Bitlis'in doğal güzelliklerinde yürüyüş yapmak favori aktivitem."
  },
  {
    emoji: "🎵",
    title: "Müzik Dinleme",
    description: "Kodlama yaparken lo-fi ve ambient müzik dinleyerek odaklanmayı seviyorum."
  },
  {
    emoji: "🧩",
    title: "Problem Çözme",
    description: "LeetCode ve HackerRank'te algoritma problemleri çözmekten keyif alıyorum."
  }
];
---

<section id="hobiler" class="hobbies" aria-label="Hobiler">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-label">// Hobiler</span>
      <h2 class="section-title">Kod Dışında <span class="gradient-text">Ben</span></h2>
      <p class="section-subtitle">Sadece bir geliştirici değilim — işte ilgi alanlarım ve motivasyon kaynaklarım.</p>
    </div>

    <div class="hobbies-grid">
      {hobbies.map((hobby, i) => (
        <div class="hobby-card card reveal" style={`--delay: ${i * 0.1}s`}>
          <span class="hobby-emoji">{hobby.emoji}</span>
          <h3 class="hobby-title">{hobby.title}</h3>
          <p class="hobby-desc">{hobby.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .hobbies {
    background: var(--bg-secondary);
  }

  .hobbies-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1.25rem;
  }

  .hobby-card {
    text-align: center;
    padding: 2rem 1.25rem;
    transition-delay: var(--delay);
  }

  .hobby-card:hover {
    transform: translateY(-6px);
  }

  .hobby-emoji {
    font-size: 2.5rem;
    display: block;
    margin-bottom: 1rem;
    transition: transform var(--transition-base);
  }

  .hobby-card:hover .hobby-emoji {
    transform: scale(1.2) rotate(5deg);
  }

  .hobby-title {
    font-size: 1rem;
    margin-bottom: 0.5rem;
  }

  .hobby-desc {
    font-size: 0.8125rem;
    color: var(--text-tertiary);
    line-height: 1.6;
  }

  @media (max-width: 1024px) {
    .hobbies-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 640px) {
    .hobbies-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 400px) {
    .hobbies-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
