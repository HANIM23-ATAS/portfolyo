---
// Hero Section
---

<section id="hero" class="hero" aria-label="Tanıtım">
  <!-- Decorative blobs -->
  <div class="blob hero-blob-1"></div>
  <div class="blob hero-blob-2"></div>
  <div class="hero-grid-bg"></div>

  <div class="container hero-container">
    <div class="hero-content reveal">
      <div class="hero-badge">
        <span class="status-dot"></span>
        İş fırsatlarına açık
      </div>

      <div class="hero-title-group">
        <img src="/avatar-placeholder.svg" alt="Hanım ATAŞ" class="hero-avatar" />
        <h1 class="hero-title">
          Merhaba, ben
          <span class="gradient-text">Hanım ATAŞ</span>
        </h1>
      </div>

      <p class="hero-role">Backend Developer & DevOps Engineer</p>

      <p class="hero-pitch">
        Bitlis Eren Üniversitesi Bilgisayar Mühendisliği öğrencisiyim. <strong>Go</strong>, <strong>TypeScript</strong> ve 
        <strong>Docker</strong> ile güvenli, ölçeklenebilir backend sistemleri geliştiriyorum. 
        Mikroservis mimarileri, CI/CD pipeline'ları ve container orkestrasyonu konularında 
        deneyime sahibim.
      </p>

      <div class="hero-actions">
        <a href="#projeler" class="btn btn-primary" id="cta-projects">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
          Projelerimi Gör
        </a>
        <a href="https://github.com/HANIM23-ATAS" target="_blank" rel="noopener noreferrer" class="btn btn-secondary" id="cta-github">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77a5.07 5.07 0 0 0-.09-3.77S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
          GitHub
        </a>
        <a href="#iletisim" class="btn btn-secondary" id="cta-contact">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          İletişim
        </a>
        <a href="/cv.pdf" target="_blank" preload="none" class="btn btn-ghost" id="cta-cv">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><polyline points="9 15 12 18 15 15"/></svg>
          CV (PDF)
        </a>
      </div>

      <div class="hero-stats">
        <div class="stat">
          <span class="stat-number">4+</span>
          <span class="stat-label">Proje</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-number">5+</span>
          <span class="stat-label">Teknoloji</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-number">3+</span>
          <span class="stat-label">Dil</span>
        </div>
      </div>
    </div>

    <div class="hero-visual reveal">
      <div class="terminal-window">
        <div class="terminal-header">
          <div class="terminal-dots">
            <span class="dot dot-red"></span>
            <span class="dot dot-yellow"></span>
            <span class="dot dot-green"></span>
          </div>
          <span class="terminal-title">~/portfolio</span>
        </div>
        <div class="terminal-body">
          <code>
            <span class="term-prompt">$</span> <span class="term-cmd">cat</span> about.json<br/>
            <span class="term-brace">&#123;</span><br/>
            &nbsp;&nbsp;<span class="term-key">"name"</span>: <span class="term-str">"Hanım ATAŞ"</span>,<br/>
            &nbsp;&nbsp;<span class="term-key">"role"</span>: <span class="term-str">"Backend Developer"</span>,<br/>
            &nbsp;&nbsp;<span class="term-key">"university"</span>: <span class="term-str">"Bitlis Eren Üniv. — Bil. Müh."</span>,<br/>
            &nbsp;&nbsp;<span class="term-key">"languages"</span>: [<span class="term-str">"Go"</span>, <span class="term-str">"TypeScript"</span>, <span class="term-str">"Python"</span>],<br/>
            &nbsp;&nbsp;<span class="term-key">"devops"</span>: [<span class="term-str">"Docker"</span>, <span class="term-str">"CI/CD"</span>, <span class="term-str">"nginx"</span>],<br/>
            &nbsp;&nbsp;<span class="term-key">"available"</span>: <span class="term-bool">true</span><br/>
            <span class="term-brace">&#125;</span><br/>
            <span class="term-prompt">$</span> <span class="term-cursor">▊</span>
          </code>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="scroll-indicator" aria-hidden="true">
    <div class="scroll-arrow"></div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    padding-top: 5rem;
  }

  .hero-grid-bg {
    position: absolute;
    inset: 0;
    background-image: 
      linear-gradient(rgba(102, 126, 234, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(102, 126, 234, 0.03) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse 80% 70% at 50% 50%, black 40%, transparent 100%);
    -webkit-mask-image: radial-gradient(ellipse 80% 70% at 50% 50%, black 40%, transparent 100%);
  }

  .hero-blob-1 {
    width: 500px;
    height: 500px;
    background: var(--accent-primary);
    top: -100px;
    right: -100px;
  }

  .hero-blob-2 {
    width: 400px;
    height: 400px;
    background: var(--accent-secondary);
    bottom: -50px;
    left: -100px;
  }

  .hero-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.375rem 1rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--success);
    background: rgba(16, 185, 129, 0.1);
    border: 1px solid rgba(16, 185, 129, 0.2);
    border-radius: var(--radius-full);
    margin-bottom: 1.5rem;
  }

  .status-dot {
    width: 8px;
    height: 8px;
    background: var(--success);
    border-radius: 50%;
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(1.3); }
  }

  .hero-title-group {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }

  .hero-avatar {
    width: 90px;
    height: 90px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid var(--accent-primary);
    box-shadow: 0 0 20px rgba(102, 126, 234, 0.4);
  }

  .hero-title {
    font-size: clamp(2.5rem, 5vw, 3.75rem);
    line-height: 1.15;
  }

  .hero-role {
    font-family: var(--font-mono);
    font-size: 1.125rem;
    color: var(--accent-primary);
    font-weight: 500;
    margin-bottom: 1.25rem;
  }

  .hero-pitch {
    font-size: 1.0625rem;
    line-height: 1.75;
    margin-bottom: 2rem;
    max-width: 540px;
  }

  .hero-pitch strong {
    color: var(--text-primary);
    font-weight: 600;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 2.5rem;
  }

  .hero-stats {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .stat-number {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--text-primary);
    line-height: 1.2;
  }

  .stat-label {
    font-size: 0.8125rem;
    color: var(--text-tertiary);
    font-weight: 500;
  }

  .stat-divider {
    width: 1px;
    height: 2rem;
    background: var(--border-color);
  }

  /* Terminal */
  .terminal-window {
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-xl);
    overflow: hidden;
    transition: all var(--transition-base);
  }

  .terminal-window:hover {
    box-shadow: var(--shadow-xl), var(--shadow-glow);
    transform: translateY(-4px);
  }

  .terminal-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.875rem 1.25rem;
    background: var(--bg-tertiary);
    border-bottom: 1px solid var(--border-color);
  }

  .terminal-dots {
    display: flex;
    gap: 0.375rem;
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }

  .dot-red { background: #ff5f57; }
  .dot-yellow { background: #febc2e; }
  .dot-green { background: #28c840; }

  .terminal-title {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--text-tertiary);
  }

  .terminal-body {
    padding: 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    line-height: 1.8;
    color: var(--text-secondary);
  }

  .term-prompt { color: var(--success); font-weight: 600; }
  .term-cmd { color: var(--accent-primary); }
  .term-brace { color: var(--text-tertiary); }
  .term-key { color: var(--accent-primary); }
  .term-str { color: var(--success); }
  .term-bool { color: var(--warning); }

  .term-cursor {
    animation: blink 1s step-end infinite;
    color: var(--accent-primary);
  }

  @keyframes blink {
    0%, 50% { opacity: 1; }
    51%, 100% { opacity: 0; }
  }

  /* Scroll indicator */
  .scroll-indicator {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
  }

  .scroll-arrow {
    width: 24px;
    height: 24px;
    border-right: 2px solid var(--text-tertiary);
    border-bottom: 2px solid var(--text-tertiary);
    transform: rotate(45deg);
    animation: scrollBounce 2s ease-in-out infinite;
  }

  @keyframes scrollBounce {
    0%, 100% { transform: rotate(45deg) translate(0, 0); opacity: 0.4; }
    50% { transform: rotate(45deg) translate(5px, 5px); opacity: 1; }
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .hero-container {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 2.5rem;
    }

    .hero-pitch {
      margin: 0 auto 2rem;
    }

    .hero-actions {
      justify-content: center;
    }

    .hero-stats {
      justify-content: center;
    }

    .hero-visual {
      max-width: 500px;
      margin: 0 auto;
    }
  }

  @media (max-width: 480px) {
    .hero-actions {
      flex-direction: column;
    }

    .hero-actions .btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>
